{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sakata-syllable-engine",
  "main": "./dist/cloudflare-worker.js",
  "compatibility_date": "2026-05-13",
  "routes": [
    {
      "pattern": "example.com/api/syllable",
      "zone_name": "example.com"
    }
  ],
  "vars": {
    "CORS_ALLOWED_ORIGIN": "https://your-frontend.example.com"
  },
  "workers_dev": false,
    "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1,
      "persist": true,
      "invocation_logs": true,
    },
    "traces": {
      "enabled": false,
      "persist": true,
      "head_sampling_rate": 1,
    },
  },
}
