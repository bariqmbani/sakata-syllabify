{
  "name": "sakata-syllable-engine",
  "version": "0.1.0",
  "description": "Deterministic Indonesian last-syllable engine for gameplay.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "npm run build:worker && wrangler dev --port 8787",
    "build": "tsc -p tsconfig.build.json",
    "build:worker": "tsc -p tsconfig.build.json",
    "deploy:worker": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "keywords": [
    "indonesian",
    "syllable",
    "word-game"
  ],
  "author": "Bariq Mbani <bariq.m70@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.3.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6",
    "wrangler": "^4.90.1"
  }
}
